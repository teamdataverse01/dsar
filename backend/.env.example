ENVIRONMENT=development
SECRET_KEY=dev-secret-key-change-me

# Set by Docker Compose automatically — override for local non-Docker runs
DATABASE_URL=postgresql://dsar_user:dsar_pass@localhost:5432/dsar_db
REDIS_URL=redis://localhost:6379/0

# Leave blank in dev — OTP will be shown on-screen instead
RESEND_API_KEY=
EMAIL_FROM=onboarding@resend.dev
EMAIL_FROM_NAME=DataVerse DSAR

# Optional: fill in your systeme.io key to enable real data lookups
SYSTEMEIO_API_KEY=

# Optional: fill in to enable AI draft generation
ANTHROPIC_API_KEY=

# Auto-generated on first boot if left blank (dev only)
ENCRYPTION_KEY=
